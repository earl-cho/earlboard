"use client";

import { useState, useEffect } from 'react';
import { createClient } from '@supabase/supabase-js';
import { MarketReport } from '@/types';
import Link from 'next/link';

// Initialize Supabase Client (Client Side)
const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL || '';
const supabaseKey = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY || '';
const supabase = createClient(supabaseUrl, supabaseKey);

export default function RestrictedPage() {
    const [isAuthenticated, setIsAuthenticated] = useState(false);
    const [password, setPassword] = useState('');
    const [loading, setLoading] = useState(false);
    const [error, setError] = useState('');
    const [reports, setReports] = useState<MarketReport[]>([]);
    const [mounted, setMounted] = useState(false);

    // Initial load and authentication check
    useEffect(() => {
        setMounted(true);
        const authStatus = sessionStorage.getItem('is_restricted_auth');
        if (authStatus === 'true') {
            setIsAuthenticated(true);
            fetchRestrictedReports();
        }
    }, []);

    const handleLogin = async (e: React.FormEvent) => {
        e.preventDefault();
        setLoading(true);
        setError('');

        try {
            const res = await fetch('/api/auth', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ password }),
            });

            if (res.ok) {
                setIsAuthenticated(true);
                sessionStorage.setItem('is_restricted_auth', 'true');
                fetchRestrictedReports();
            } else {
                setError('Incorrect password');
            }
        } catch (err) {
            setError('An error occurred');
        } finally {
            setLoading(false);
        }
    };

    const fetchRestrictedReports = async () => {
        try {
            const { data, error } = await supabase
                .from('market_reports')
                .select('*')
                .contains('tags', ['REGULATION_AGENT'])
                .order('created_at', { ascending: false });

            if (error) throw error;
            setReports((data as MarketReport[]) || []);
        } catch (err) {
            console.error('Error fetching reports:', err);
        }
    };

    if (!isAuthenticated) {
        return (
            <div className="min-h-screen flex items-center justify-center bg-slate-950 px-4">
                <div className="max-w-md w-full bg-slate-900 border border-slate-800 p-8 rounded-2xl shadow-2xl">
                    <div className="text-center mb-8">
                        <div className="mx-auto w-12 h-12 bg-red-500/20 text-red-500 rounded-full flex items-center justify-center mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" strokeWidth={1.5} stroke="currentColor" className="w-6 h-6">
                                <path strokeLinecap="round" strokeLinejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                            </svg>
                        </div>
                        <h2 className="text-2xl font-bold text-white mb-2">Restricted Access</h2>
                        <p className="text-slate-400 text-sm">Authorized personnel only. Enter access code.</p>
                    </div>

                    <form onSubmit={handleLogin} className="space-y-4">
                        <div>
                            <input
                                type="password"
                                value={password}
                                onChange={(e) => setPassword(e.target.value)}
                                className="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-red-500/50 transition-all font-mono text-center tracking-widest"
                                placeholder="••••••••"
                                autoFocus
                            />
                        </div>

                        {error && (
                            <div className="text-red-400 text-xs text-center font-medium animate-pulse">
                                {error}
                            </div>
                        )}

                        <button
                            type="submit"
                            disabled={loading}
                            className="w-full bg-gradient-to-r from-red-600 to-red-500 hover:from-red-500 hover:to-red-400 text-white font-bold py-3 rounded-xl transition-all transform active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed shadow-lg shadow-red-900/20"
                        >
                            {loading ? 'Verifying...' : 'UNLOCK INTELLIGENCE'}
                        </button>
                    </form>
                </div>
            </div>
        );
    }

    return (
        <div className="min-h-screen bg-slate-950 text-white pb-20">
            {/* Header */}
            <div className="bg-red-950/20 border-b border-red-500/10 pt-32 pb-12">
                <div className="container mx-auto px-6">
                    <div className="flex flex-col md:flex-row md:items-end justify-between gap-6">
                        <div>
                            <div className="inline-flex items-center gap-2 px-3 py-1 bg-red-500/10 border border-red-500/20 rounded-full mb-4">
                                <div className="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse" />
                                <span className="text-[10px] font-bold uppercase tracking-widest text-red-500">CONFIDENTIAL</span>
                            </div>
                            <h1 className="text-4xl md:text-5xl font-black uppercase tracking-tight mb-4">
                                Strategic <span className="text-slate-500">War Room</span>
                            </h1>
                            <p className="text-slate-400 max-w-2xl text-lg leading-relaxed">
                                High-level intelligence reports for executive decision making.
                                Focus on Regulatory Arbitrage, Enterprise Adoption, and Compliance Defense.
                            </p>
                        </div>

                        <button
                            onClick={() => {
                                sessionStorage.removeItem('is_restricted_auth');
                                setIsAuthenticated(false);
                            }}
                            className="text-slate-500 hover:text-white transition-colors text-sm font-bold uppercase tracking-widest"
                        >
                            Lock Terminal
                        </button>
                    </div>
                </div>
            </div>

            {/* Content List */}
            <div className="container mx-auto px-6 py-12">
                {reports.length === 0 ? (
                    <div className="text-center py-20">
                        <p className="text-slate-500">No strategic reports available yet.</p>
                    </div>
                ) : (
                    <div className="max-w-4xl mx-auto space-y-6">
                        {reports.map((report) => (
                            <Link key={report.id} href={`/report/${report.id}`} className="block">
                                <div className="bg-slate-900/50 border border-white/5 rounded-2xl p-6 hover:bg-slate-900 hover:border-red-500/30 transition-all group">
                                    <div className="flex flex-wrap gap-2 mb-4">
                                        {report.tags.map(tag => (
                                            <span key={tag} className="text-[9px] font-bold text-red-400 uppercase tracking-widest bg-red-500/10 px-2 py-0.5 rounded">
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                    <h3 className="text-xl font-bold text-white uppercase tracking-tight mb-3 group-hover:text-red-400 transition-colors">
                                        {report.title}
                                    </h3>
                                    <p className="text-slate-400 text-sm leading-relaxed mb-4 line-clamp-2">
                                        {report.summary_3lines}
                                    </p>
                                    <div className="flex items-center justify-between pt-4 border-t border-white/5">
                                        <span className="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                            {mounted ? new Date(report.created_at).toLocaleDateString() : '---'}
                                        </span>
                                        <span className="text-[10px] font-black text-white uppercase tracking-widest flex items-center gap-2">
                                            READ FULL REPORT <span className="text-red-500">→</span>
                                        </span>
                                    </div>
                                </div>
                            </Link>
                        ))}
                    </div>
                )}
            </div>
        </div>
    );
}

